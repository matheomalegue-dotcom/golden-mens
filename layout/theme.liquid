<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#07090D">
  <title>{{ page_title }}{% unless page_title contains 'Golden Mens' %} — Golden Mens{% endunless %}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=Inter:wght@300;400;500;600;700&family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
</head>
<body>
  {% section 'header' %}
  {{ content_for_layout }}

  <div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>
  <aside class="cart-drawer" id="cart-drawer">
    <div class="cart-drawer-head">
      <span class="cart-drawer-title">Your Cart</span>
      <button class="cart-drawer-close" onclick="closeCart()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="cart-drawer-body" id="cart-body"></div>
    <div class="cart-drawer-foot" id="cart-foot"></div>
  </aside>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
