{% if request.path == '/' or request.path == '' %}

<nav class="anim-fade">
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="logo">
      <img src="{{ 'logo.png' | asset_url }}" alt="Golden Mens" style="height:64px;width:auto;display:block;mix-blend-mode:screen;">
    </a>
    <div class="nav-links">
      <a href="#services">Services</a>
      <a href="#about">About</a>
      <a href="#gallery">Gallery</a>
      <a href="#contact">Contact</a>
    </div>
    <div style="display:flex;align-items:center;gap:20px;">
      <a href="tel:+14389928101" class="nav-phone">✦ (438) 992-8101</a>
      <button class="cart-nav-btn" onclick="openCart()" aria-label="Open cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-nav-count" id="cart-count"></span>
      </button>
      <a href="#locations" class="btn-nav">Book Now</a>
    </div>
  </div>
</nav>

{% else %}

<nav class="anim-fade">
  <div class="nav-inner nav-inner--subpage">
    <a href="{{ routes.root_url }}" class="logo">
      <img src="{{ 'logo.png' | asset_url }}" alt="Golden Mens" style="height:64px;width:auto;display:block;mix-blend-mode:screen;">
    </a>
    <a href="{{ routes.root_url }}" class="nav-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      Back to Golden Mens
    </a>
    <button class="cart-nav-btn cart-nav-btn--subpage" onclick="openCart()" aria-label="Open cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-nav-count" id="cart-count"></span>
    </button>
  </div>
</nav>

{% endif %}

{% schema %}
{ "name": "Header", "settings": [] }
{% endschema %}
