<section class="hero">
  <div class="hero-left">
    <div class="hero-inner">
      <div class="hero-tag anim">
        <span class="hero-tag-dot"></span>
        Montreal's #1 Luxury Barbershop
      </div>
      <h1 class="hero-h1 anim">
        <span class="line-fade">Montreal's</span>
        <span class="word-fade">Best</span> <span class="accent">Barbershop</span><br>
        <span class="last-line">Experience</span>
      </h1>
      <div class="hero-divider anim"></div>
      <p class="hero-sub anim">
        Where precision meets artistry. Premium cuts, straight razor shaves, and an elevated grooming experience crafted exclusively for the modern gentleman.
      </p>
      <div class="hero-ctas anim">
        <a href="#locations" class="btn-primary">
          Book Appointment
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="tel:+14389928101" class="btn-ghost">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.32 2 2 0 0 1 3.62 1.14h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Now
        </a>
      </div>
      <div class="hero-trust anim">
        <div class="hero-stars">
          <div class="stars-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A048"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A048"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A048"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A048"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A048"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <span class="stars-text">200+ Five-Star Reviews</span>
        </div>
        <div class="hero-badges">
          <div class="hero-badge"><div class="badge-dot"><svg width="8" height="8" viewBox="0 0 12 12" fill="none" stroke="#07090D" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></div><span>Master Barbers</span></div>
          <div class="hero-badge"><div class="badge-dot"><svg width="8" height="8" viewBox="0 0 12 12" fill="none" stroke="#07090D" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></div><span>Premium Products</span></div>
          <div class="hero-badge"><div class="badge-dot"><svg width="8" height="8" viewBox="0 0 12 12" fill="none" stroke="#07090D" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></div><span>Walk-ins Welcome</span></div>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-right anim-img">
    <img src="{{ 'goldenmens1.png' | asset_url }}" alt="Golden Mens Barbershop">
  </div>
  <div class="hero-grain"></div>
</section>

{% schema %}
{ "name": "Hero", "settings": [] }
{% endschema %}
