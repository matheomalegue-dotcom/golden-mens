{% style %}
.reviews-section {
  padding: 100px 0 120px;
  overflow: hidden;
}
.reviews-header {
  text-align: center;
  margin-bottom: 72px;
  padding: 0 40px;
}
.reviews-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-size: 10px;
  font-weight: 500;
  color: rgba(201,160,72,0.75);
  letter-spacing: 0.28em;
  text-transform: uppercase;
  margin-bottom: 24px;
}
.reviews-eyebrow::before, .reviews-eyebrow::after {
  content: '';
  display: block;
  width: 28px;
  height: 1px;
  background: rgba(201,160,72,0.45);
}
.reviews-title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(26px, 4vw, 50px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: white;
  margin-bottom: 16px;
}
.reviews-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.06em;
}
.reviews-rating-summary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 20px;
  padding: 10px 20px;
  border: 1px solid rgba(201,160,72,0.15);
  border-radius: 2px;
}
.reviews-rating-stars {
  display: flex;
  gap: 3px;
  color: #EDD07A;
  font-size: 14px;
}
.reviews-rating-text {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
}
.reviews-rating-score {
  font-size: 13px;
  font-weight: 800;
  background: linear-gradient(135deg, #EDD07A 0%, #C9A048 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.reviews-row {
  margin-bottom: 24px;
  position: relative;
}
.reviews-row:last-child {
  margin-bottom: 0;
}
.reviews-row::before,
.reviews-row::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 120px;
  z-index: 2;
  pointer-events: none;
}
.reviews-row::before {
  left: 0;
  background: linear-gradient(to right, #07090D, transparent);
}
.reviews-row::after {
  right: 0;
  background: linear-gradient(to left, #07090D, transparent);
}
.reviews-track {
  display: flex;
  gap: 20px;
  width: max-content;
  animation: marquee-left 55s linear infinite;
}
.reviews-track--reverse {
  animation: marquee-right 60s linear infinite;
}
.reviews-track:hover,
.reviews-track--reverse:hover {
  animation-play-state: paused;
}

@keyframes marquee-left {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@keyframes marquee-right {
  from { transform: translateX(-50%); }
  to   { transform: translateX(0); }
}

.review-card {
  width: 320px;
  flex-shrink: 0;
  background: rgba(14,17,24,0.85);
  border: 1px solid rgba(201,160,72,0.10);
  border-radius: 3px;
  padding: 28px;
  transition: border-color 0.3s ease;
  position: relative;
}
.review-card:hover {
  border-color: rgba(201,160,72,0.22);
}
.review-card-quote {
  position: absolute;
  top: 20px;
  right: 24px;
  font-size: 56px;
  line-height: 1;
  color: rgba(201,160,72,0.06);
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  pointer-events: none;
  user-select: none;
}
.review-stars {
  display: flex;
  gap: 3px;
  margin-bottom: 16px;
}
.review-stars span {
  color: #EDD07A;
  font-size: 13px;
}
.review-text {
  font-size: 13.5px;
  line-height: 1.7;
  color: rgba(255,255,255,0.72);
  margin-bottom: 20px;
}
.review-divider {
  width: 28px;
  height: 1px;
  background: linear-gradient(to right, rgba(201,160,72,0.35), transparent);
  margin-bottom: 16px;
}
.review-author {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
{% endstyle %}

